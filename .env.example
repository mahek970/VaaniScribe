DEEPGRAM_API_KEY=your_deepgram_key
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_SAMPLE_RATE=16000
DEEPGRAM_CHANNELS=1
DEEPGRAM_WS_OPEN_TIMEOUT=45
DEEPGRAM_MAX_RETRY_SECONDS=20
DEEPGRAM_INPUT_DEVICE=2
DEEPGRAM_SILENCE_RMS=120
DEEPGRAM_INPUT_GAIN=1.0
DEEPGRAM_AUTO_FALLBACK_DEVICE=true
DEEPGRAM_AUTO_SWITCH_ON_DEVICE_LOSS=true
DEEPGRAM_INTERIM_RESULTS=true
TRANSCRIPT_BRIDGE_PATH=live_transcript.json
TRANSCRIPT_MAX_LINES=2000
TRANSCRIPT_MERGE_WINDOW_SECONDS=2.0
TRANSCRIPT_UI_REFRESH_SECONDS=2
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-1.5-flash
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ACCOUNT=your_org-account
SNOWFLAKE_DATABASE=MEETINGMIND
SNOWFLAKE_SCHEMA=MEETINGS
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_ROLE=your_role
DIGITALOCEAN_APP_URL=your_app_url
